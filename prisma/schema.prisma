generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Products {
  id         Int      @id @default(autoincrement())
  title      String
  subtitle   String
  desc       String
  image      String
  slug       String   @unique
  watching   Int
  subImages  Json     // JSON array of strings
  paragraphs Json     // JSON array

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum TestimonialStatus {
  APPROVE
  REJECTED
  NEW
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  position  String
  comment   String
  image     String
  status    TestimonialStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Blog {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  image     String
  content   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id             Int      @id @default(autoincrement())
  title          String
  level          String
  slug           String   @unique
  description    String
  qualifications Json
  experience     Json
  offers         Json
  salary         String
  imageUrl       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ShowAtType {
  PLANTATION
  GROUP
  TOURS
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  name      String
  title     String
  bio       String
  imageUrl  String
  showAt    Json     // JSON array of enum values

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id        Int      @id @default(autoincrement())
  name      String
  logo      String
  bg        String
  link      String
  bgcolor   String
  blank     Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  username  String   @unique
  password  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
